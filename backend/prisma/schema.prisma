// GPS World Lap Time Counter - Database Schema
// Version: 2.2 (Multi-Sport Support)
// Date: 2026-07-08

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========== ユーザー管理 ==========

model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  passwordHash String?  @map("password_hash")
  name         String
  role         UserRole @default(DRIVER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // リレーション
  courses Course[]
  events  Event[]
  laps    Lap[]

  @@map("users")
}

enum UserRole {
  DRIVER     // 一般参加者
  ORGANIZER  // イベント運営者
  ADMIN      // システム管理者
}

// ========== コース管理（マルチスポーツ対応） ==========

model Course {
  id                 String      @id @default(uuid())
  country            String      // 国 (例: "Japan", "USA")
  state              String?     // 都道府県/州 (例: "Mie", "California")
  name               String      // コース名 (例: "Suzuka Circuit", "Tokyo Marathon Course")
  courseType         CourseType  @default(CLOSED_CIRCUIT) @map("course_type")
  sportCategories    Json        @map("sport_categories") // ['car', 'motorcycle', 'bicycle', 'running', ...]
  controlLineALat    Decimal     @map("control_line_a_lat") @db.Decimal(10, 7)
  controlLineALng    Decimal     @map("control_line_a_lng") @db.Decimal(10, 7)
  controlLineBLat    Decimal     @map("control_line_b_lat") @db.Decimal(10, 7)
  controlLineBLng    Decimal     @map("control_line_b_lng") @db.Decimal(10, 7)
  referenceTime      Int?        @map("reference_time") // 秒単位
  courseLength       Decimal?    @map("course_length") @db.Decimal(5, 2) // km
  elevationGain      Int?        @map("elevation_gain") // m（高低差）
  description        String?     @db.Text
  isPublic           Boolean     @default(true) @map("is_public")
  createdBy          String?     @map("created_by")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  // リレーション
  creator User?   @relation(fields: [createdBy], references: [id])
  events  Event[]

  @@unique([country, state, name]) // 重複防止
  @@index([country, state]) // 検索高速化
  @@map("courses")
}

enum CourseType {
  CLOSED_CIRCUIT // クローズドサーキット（専用コース）
  PUBLIC_ROAD    // 一般道・公道
  FARM_ROAD      // 農道・林道
  TRAIL          // トレイル・山道
  WATER          // 水上（海・湖・川）
  OTHER          // その他
}

// ========== イベント管理（マルチスポーツ対応） ==========

model Event {
  id              String        @id @default(uuid())
  name            String        // イベント名
  courseId        String        @map("course_id")
  sportCategory   SportCategory @map("sport_category") // イベント対象スポーツカテゴリ
  eventDate       DateTime      @map("event_date") @db.Date
  eventCode       String        @unique @map("event_code") // 6桁コード (例: ABC123)
  maxParticipants Int?          @map("max_participants")
  isPublic        Boolean       @default(true) @map("is_public")
  organizerId     String        @map("organizer_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // リレーション
  course    Course @relation(fields: [courseId], references: [id], onDelete: Restrict)
  organizer User   @relation(fields: [organizerId], references: [id])
  laps      Lap[]

  @@index([eventCode])
  @@index([eventDate])
  @@index([courseId])
  @@index([sportCategory]) // スポーツカテゴリでの検索高速化
  @@map("events")
}

enum SportCategory {
  CAR                // 車（四輪）
  MOTORCYCLE         // バイク（二輪）
  KART               // カート
  BICYCLE_ROAD       // ロードバイク
  BICYCLE_MTB        // MTB
  BICYCLE_CYCLOCROSS // シクロクロス
  RUNNING            // ランニング
  RUNNING_MARATHON   // マラソン
  RUNNING_TRAIL      // トレイルランニング
  SKIING             // スキー
  SNOWBOARDING       // スノーボード
  BOAT               // ボート
  CANOE              // カヌー
  OTHER              // その他
}

// ========== ラップ記録（マルチスポーツ対応） ==========

model Lap {
  id              String        @id @default(uuid())
  eventId         String        @map("event_id")
  userId          String?       @map("user_id") // ログインユーザーの場合
  participantName String        @map("participant_name") // ドライバー/ランナー/ライダー等
  sportCategory   SportCategory @map("sport_category") // スポーツカテゴリ
  vehicleOrGear   String?       @map("vehicle_or_gear") // 車両/装備情報（車両名、自転車、シューズ等）
  lapNumber       Int           @map("lap_number")
  lapTimeMs       Int           @map("lap_time_ms") // ミリ秒
  lapTimeStr      String        @map("lap_time_str") // 表示用 (例: "1:23.456")
  recordedAt      DateTime      @default(now()) @map("recorded_at")

  // リレーション
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@index([eventId, lapTimeMs]) // ランキング高速化
  @@index([userId])
  @@index([sportCategory]) // スポーツカテゴリでの検索高速化
  @@index([recordedAt])
  @@map("laps")
}
